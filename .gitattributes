# Auto detect and normalize line endings
* text=auto

# Source files - LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows batch - CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.woff binary
*.woff2 binary

# iOS/Android specific
*.pbxproj merge=union
*.plist text eol=lf
*.gradle text eol=lf

# Certificates and keys
*.p8 binary
*.p12 binary
*.mobileprovision binary
*.jks binary
*.keystore binary
