# RevenueCat - In-app purchases
# Get API key from: https://app.revenuecat.com/
EXPO_PUBLIC_REVENUECAT_API_KEY=your_revenuecat_api_key_here

# Sentry - Error tracking (required for production)
# Get DSN from: https://sentry.io/
EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id

# Environment identifier
# Values: development, staging, production
EXPO_PUBLIC_ENVIRONMENT=development
